        <mxCell id="qOmzMdP77np9UpU3_EpL-18" parent="qOmzMdP77np9UpU3_EpL-17" style="shape=partialRectangle;connectable=0;fillColor=none;top=0;left=0;bottom=0;right=0;fontStyle=1;overflow=hidden;whiteSpace=wrap;html=1;" value="대안흐름" vertex="1">
