        </mxCell>
        <mxCell id="LVaz8bQsQqEIjGHbkDQo-20" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=12;" value="(C) 회원은 진단결과를 저장 할 수 있다&lt;div&gt;(R) 회원은 진단결과를 조회 할 수 있다&lt;/div&gt;&lt;div&gt;(U) 회원은 진단결과를 수정 할 수 있다&lt;/div&gt;&lt;div&gt;(D) 회원은 진단결과를 삭제 할 수 있다&lt;/div&gt;" vertex="1">
          <mxGeometry height="70" width="210" x="55" y="335" as="geometry" />
        </mxCell>
        <mxCell id="LVaz8bQsQqEIjGHbkDQo-21" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=12;" value="&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;(R) 회원은 나의정보를 조회 할 수 있다&lt;/span&gt;&lt;/div&gt;&lt;div&gt;(U) 회원은 나의정보를 수정 할 수 있다&lt;/div&gt;&lt;div&gt;(D) 회원은 회원탈퇴를 할 수 있다&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;(P) 회원은 로그인을 할 수 있다&lt;/div&gt;&lt;div&gt;(P) 회원은 로그아웃을&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;할 수 있다&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="110" width="210" x="55" y="155" as="geometry" />
        </mxCell>
        <mxCell id="LVaz8bQsQqEIjGHbkDQo-22" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=12;" value="(R) 회원은 제품 정보를 조회 할 수 있다&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;(P) 회원은 제품을 구매 할 수 있다&lt;/div&gt;&lt;div&gt;(P) 회원은 반품, 환불을 할 수 있다&lt;/div&gt;&lt;div&gt;(P) 회원은 제품 문의를 할 수 있다&lt;/div&gt;" vertex="1">
          <mxGeometry height="90" width="220" x="55" y="505" as="geometry" />
        </mxCell>
        <mxCell id="LVaz8bQsQqEIjGHbkDQo-23" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=12;" value="&lt;br&gt;&lt;div&gt;(C) 비회원은 회원가입을 할 수 있다&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="60" width="200" x="305" y="170" as="geometry" />
        </mxCell>
        <mxCell id="LVaz8bQsQqEIjGHbkDQo-25" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=12;" value="&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;(R) 판매자는 나의 정보를 조회 할 수 있다&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;(U) 판매자는&amp;nbsp;&lt;/span&gt;나의 정보를 수정 할 수 있다&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;(D) 판매자는&lt;/span&gt;&amp;nbsp;회원탈퇴를 할 수 있다&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;(P) 판매자는&lt;/span&gt;&amp;nbsp;로그인을 할 수 있다&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;(P) 판매자는&lt;/span&gt;&amp;nbsp;로그아웃을&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;할 수 있다&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
